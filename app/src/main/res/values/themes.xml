<resources>
    <style name="Theme.PixelLauncherV2" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/pixel_on</item>
        <item name="colorPrimaryVariant">@color/pixel_on</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/pixel_accent</item>
        <item name="colorSecondaryVariant">@color/pixel_accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/pixel_background</item>
        <item name="android:navigationBarColor">@color/pixel_background</item>
        <item name="android:windowBackground">@color/pixel_background</item>
        <item name="android:windowAnimationStyle">@style/PixelLauncherWindowAnimation</item>
    </style>

    <style name="PixelLauncherWindowAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/no_anim</item>
        <item name="android:activityOpenExitAnimation">@anim/no_anim</item>
        <item name="android:activityCloseEnterAnimation">@anim/no_anim</item>
        <item name="android:activityCloseExitAnimation">@anim/no_anim</item>
    </style>
</resources>
